// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CaseStudy {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  subtitle         String
  image            String
  heroImage        String
  industry         String
  businessFunction String
  description      String   @db.Text

  // --- Client Info (Deep Dive) ---
  clientName       String?
  clientIndustry   String?
  clientMarket     String?
  clientTechnology String?

  // ---NutShell ---
  challenges String @db.Text
  solution String @db.Text
  benefits String @db.Text

  

  // -- Deep Dive ---
   overview String? @db.Text
   client String?   @db.Text
   challenge String?   @db.Text
   keyConstraints String?   @db.Text

  

  // --- Solution (The 7 Agents/Modules) ---
  
  solutionAgents Json?   // Stores Array<{ title: string, description: string }>

  // --- Technology Stack ---

  tech Json?     // Stores Array<{ title: string, description: string }>

  

  // --- Unique Solution ---
  uniqueSolution String?


  // --- Final Notes ---
  results String? @db.Text
  summary        String? @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([industry])
  @@index([businessFunction])
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}